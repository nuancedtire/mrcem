---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCategories, getNotesByCategory } from '../../data/notes';

export async function getStaticPaths() {
  return getCategories().map(cat => ({
    params: { category: cat.slug },
    props: { cat },
  }));
}

const { cat } = Astro.props;
const hasSubcategories = cat.subcategories.length > 0;
const notes = hasSubcategories ? [] : getNotesByCategory(cat.slug);
---

<Base title={cat.name}>
  <Breadcrumb crumbs={[{ label: cat.name }]} />

  <h1 class="section-title">{cat.name}</h1>
  <p class="section-subtitle">{cat.count} notes{hasSubcategories ? ` · ${cat.subcategories.length} sections` : ''}</p>

  {hasSubcategories ? (
    <div class="subcat-grid">
      {cat.subcategories.map(sub => (
        <a href={`/${cat.slug}/${sub.slug}/`} class="subcat-card">
          <div class="subcat-card-name">{sub.name}</div>
          <div class="subcat-card-count">{sub.count} notes</div>
        </a>
      ))}
    </div>
  ) : (
    <div class="note-list">
      {notes.map(note => (
        <a href={`/note/${note.nid}/`} class="note-item">
          <span class="note-item-title">{note.title}</span>
        </a>
      ))}
    </div>
  )}
</Base>
