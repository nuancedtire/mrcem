---
import Base from '../layouts/Base.astro';
import { getCategories } from '../data/notes';

const categories = getCategories();
const totalNotes = categories.reduce((s, c) => s + c.count, 0);

const catDescriptions: Record<string, string> = {
  'anatomy': 'Regional structures, surface landmarks, and applied surgical anatomy',
  'physiology': 'Cellular, cardiovascular, respiratory, renal, and endocrine function',
  'pharmacology': 'Drug mechanisms, dosing, interactions, and emergency protocols',
  'microbiology': 'Bacteria, viruses, fungi, parasites, and infection management',
  'pathology': 'Disease processes, pathophysiology, and clinical presentations',
  'evidenced-based-medicine': 'Research methodology, statistics, and clinical guidelines',
};
---

<Base title="MRCEM Notes">
  <div class="home-hero">
    <h1 class="home-title">MRCEM<br/>Study<br/>Notes</h1>
    <p class="home-lead">
      Emergency medicine board preparation —
      {totalNotes.toLocaleString()} structured notes across {categories.length} core disciplines.
    </p>
  </div>

  <nav class="cat-index" aria-label="Subject areas">
    {categories.map(cat => (
      <a href={`/${cat.slug}/`} class="cat-row" data-astro-prefetch>
        <span class="cat-row-num">{String(cat.num).padStart(2, '0')}</span>
        <span class="cat-row-body">
          <span class="cat-row-name">{cat.name}</span>
          <span class="cat-row-desc">{catDescriptions[cat.slug] ?? ''}</span>
        </span>
        <span class="cat-row-right">
          <span class="cat-row-count">{cat.count} notes</span>
          <svg class="cat-row-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </span>
      </a>
    ))}
  </nav>
</Base>
