---
import Base from '../layouts/Base.astro';
import { getCategories } from '../data/notes';

const categories = getCategories();

const catDescriptions: Record<string, string> = {
  'anatomy': 'Surface anatomy, regional structures, and applied surgical landmarks.',
  'physiology': 'Cellular, cardiovascular, respiratory, renal, and endocrine function.',
  'pharmacology': 'Drug mechanisms, interactions, and emergency pharmacology.',
  'microbiology': 'Bacteria, viruses, fungi, parasites, and infection management.',
  'pathology': 'Disease processes, pathophysiology, and clinical presentations.',
  'evidence-based-medicine': 'Research methodology, statistics, and clinical guidelines.',
};
---

<Base title="MRCEM Notes">
  <div style="animation: fadeSlideIn 0.4s ease both">
    <h1 class="hero-title">MRCEM<br/>Study Notes</h1>
    <p class="hero-subtitle">
      {categories.reduce((s, c) => s + c.count, 0).toLocaleString()} notes across {categories.length} disciplines
    </p>

    <div class="category-grid">
      {categories.map(cat => (
        <a href={`/${cat.slug}/`} class="category-card">
          <div class="category-card-num">0{cat.num}</div>
          <div class="category-card-name">{cat.name}</div>
          <div class="category-card-count">{cat.count} notes{cat.subcategories.length > 0 ? ` · ${cat.subcategories.length} sections` : ''}</div>
          {catDescriptions[cat.slug] && (
            <p style="margin: 0.75rem 0 0; font-size: 0.82rem; color: var(--muted); line-height: 1.5; font-family: 'Source Serif 4', serif;">
              {catDescriptions[cat.slug]}
            </p>
          )}
        </a>
      ))}
    </div>
  </div>
</Base>
