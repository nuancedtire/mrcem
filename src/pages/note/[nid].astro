---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import NoteBody from '../../components/NoteBody.astro';
import Pagination from '../../components/Pagination.astro';
import Toc from '../../components/Toc.astro';
import { getAllNotes, getNoteByNid, getAdjacentNotes, getRelatedNotes } from '../../data/notes';

export async function getStaticPaths() {
  return getAllNotes().map(note => ({ params: { nid: note.nid } }));
}

const { nid } = Astro.params;
const note = getNoteByNid(nid)!;
const { prev, next } = getAdjacentNotes(nid);
const relatedNotes = getRelatedNotes(nid);

const crumbs = [
  { label: note.categoryName, href: `/${note.categorySlug}/` },
  ...(note.subcategorySlug
    ? [{ label: note.subcategoryName, href: `/${note.categorySlug}/${note.subcategorySlug}/` }]
    : []),
  { label: note.title },
];

const hasToc = note.headings.length > 1;
---

<Base title={note.title} description={`${note.categoryName} note: ${note.title}`} showProgress hasToc={hasToc}>
  <Breadcrumb crumbs={crumbs} />

  <article>
    <h1 class="note-title" data-pagefind-meta="title">{note.title}</h1>
    <div class="note-meta">
      <a href={`/${note.categorySlug}/`} data-pagefind-filter="category">{note.categoryName}</a>
      {note.subcategoryName && (
        <>
          <span class="note-meta-sep">·</span>
          <a href={`/${note.categorySlug}/${note.subcategorySlug}/`}>{note.subcategoryName}</a>
        </>
      )}
    </div>

    {hasToc && (
      <details class="toc-inline">
        <summary class="toc-inline-summary">On this page</summary>
        <ul class="toc-inline-list">
          {note.headings.map(h => (
            <li>
              <a href={`#${h.id}`} class="toc-inline-link" data-level={h.level}>{h.text}</a>
            </li>
          ))}
        </ul>
      </details>
    )}

    <NoteBody html={note.bodyHtml} />

    {relatedNotes.length > 0 && (
      <aside class="related-notes">
        <h2 class="related-notes-heading">See also</h2>
        <ul class="related-notes-list">
          {relatedNotes.map(rel => (
            <li>
              <a href={`/note/${rel.nid}/`} class="related-note-link">
                <span class="related-note-title">{rel.title}</span>
                <span class="related-note-meta">{rel.categoryName}{rel.subcategoryName ? ` · ${rel.subcategoryName}` : ''}</span>
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </article>

  <Pagination prev={prev} next={next} />
  {hasToc && <Toc headings={note.headings} slot="toc" />}
</Base>
