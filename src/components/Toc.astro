---
import type { TocHeading } from '../data/notes';

interface Props {
  headings: TocHeading[];
}

const { headings } = Astro.props;

if (headings.length === 0) return null;
---

<aside class="toc-wrapper" aria-label="On this page">
  <p class="toc-heading">On this page</p>
  <ul class="toc-list">
    {headings.map(h => (
      <li>
        <a href={`#${h.id}`} class="toc-link" data-level={h.level} data-toc-link>
          {h.text}
        </a>
      </li>
    ))}
  </ul>
</aside>

<script>
  function initToc() {
    const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
    if (links.length === 0) return;

    const ids = Array.from(links).map(a => a.getAttribute('href')!.slice(1));
    const targets = ids
      .map(id => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];
    if (targets.length === 0) return;

    // Track which headings are currently in the viewport's reading zone
    const intersecting = new Set<string>();

    function updateActive() {
      // Pick the first heading in document order that is inside the intersection zone
      let activeId = targets.find(t => intersecting.has(t.id))?.id ?? null;

      // Fallback when scrolled below all headings or between sections:
      // highlight the last heading that has passed the topbar
      if (!activeId) {
        for (let i = targets.length - 1; i >= 0; i--) {
          if (targets[i].getBoundingClientRect().top <= 80) {
            activeId = targets[i].id;
            break;
          }
        }
      }

      links.forEach(link => {
        link.classList.toggle('active', link.getAttribute('href') === `#${activeId}`);
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        // Each callback only delivers *changed* entries — accumulate state in a Set
        for (const entry of entries) {
          if (entry.isIntersecting) {
            intersecting.add(entry.target.id);
          } else {
            intersecting.delete(entry.target.id);
          }
        }
        updateActive();
      },
      // Top offset matches the fixed topbar; bottom clipped to top 40% of viewport
      // so only headings in the active reading zone are highlighted
      { rootMargin: '-76px 0px -60% 0px', threshold: 0 }
    );

    targets.forEach(t => observer.observe(t));

    // Disconnect when Astro swaps the page so the old observer doesn't leak
    document.addEventListener('astro:before-swap', () => observer.disconnect(), { once: true });
  }

  // astro:page-load fires on both first load and after each navigation — no manual readyState check needed
  document.addEventListener('astro:page-load', initToc);
</script>
