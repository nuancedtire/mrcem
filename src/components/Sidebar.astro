---
import type { Category } from '../data/notes';

interface Props {
  categories: Category[];
  currentPath: string;
}

const { categories, currentPath } = Astro.props;

function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<nav id="sidebar" class="sidebar" aria-label="Main navigation">
  <p class="sidebar-heading">Categories</p>

  {categories.map(cat => {
    const catActive = isActive(`/${cat.slug}`);
    const hasSubs = cat.subcategories.length > 0;
    return (
      <div class="sidebar-section" data-cat-slug={cat.slug}>
        {hasSubs ? (
          <button
            type="button"
            class:list={['sidebar-cat sidebar-toggle', { active: catActive }]}
            aria-expanded={catActive ? 'true' : 'false'}
            aria-controls={`sublist-${cat.slug}`}
          >
            <span class="sidebar-cat-label">
              <svg class="sidebar-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9" />
              </svg>
              {cat.name}
            </span>
            <span class="sidebar-count">{cat.count}</span>
          </button>
        ) : (
          <a
            href={`/${cat.slug}/`}
            class:list={['sidebar-cat', { active: catActive }]}
          >
            <span class="sidebar-cat-label">
              {cat.name}
            </span>
            <span class="sidebar-count">{cat.count}</span>
          </a>
        )}

        {hasSubs && (
          <div
            id={`sublist-${cat.slug}`}
            class:list={['sidebar-sublist', { open: catActive }]}
            style={catActive ? '' : 'height: 0px;'}
          >
            <div class="sidebar-sublist-content">
              {cat.subcategories.map(sub => (
                <a
                  href={`/${cat.slug}/${sub.slug}/`}
                  class:list={['sidebar-sub', { active: isActive(`/${cat.slug}/${sub.slug}`) }]}
                >
                  {sub.name}
                  <span class="sidebar-count">{sub.count}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    );
  })}

  <div class="sidebar-divider" />

  <div class="sidebar-section">
    <a href="/search/" class:list={['sidebar-cat', { active: currentPath === '/search/' }]}>
      <span class="sidebar-cat-label">
        Search
      </span>
    </a>
  </div>
</nav>

<script is:inline>
  (function () {
    const SIDEBAR_OPEN_KEY = 'sidebar-open-cats';

    function getOpenCats() {
      try {
        const raw = localStorage.getItem(SIDEBAR_OPEN_KEY);
        return raw ? JSON.parse(raw) : [];
      } catch {
        return [];
      }
    }

    function setOpenCats(cats) {
      try {
        localStorage.setItem(SIDEBAR_OPEN_KEY, JSON.stringify(cats));
      } catch {}
    }

    function isPathActive(href) {
      var path = location.pathname;
      return path === href || path.startsWith(href + '/');
    }

    function toggleSection(btn, sublist, slug, shouldOpen) {
      if (shouldOpen) {
        sublist.style.height = sublist.scrollHeight + 'px';
        btn.setAttribute('aria-expanded', 'true');
        btn.classList.add('expanded');
      } else {
        sublist.style.height = '0px';
        btn.setAttribute('aria-expanded', 'false');
        btn.classList.remove('expanded');
      }
    }

    function init() {
      var sidebar = document.getElementById('sidebar');
      if (!sidebar) return;

      var openCats = getOpenCats();
      var toggles = sidebar.querySelectorAll('.sidebar-toggle');

      toggles.forEach(function (btn) {
        var section = btn.closest('.sidebar-section');
        if (!section) return;
        var slug = section.getAttribute('data-cat-slug');
        var sublist = document.getElementById('sublist-' + slug);
        if (!sublist || !slug) return;

        var active = isPathActive('/' + slug);
        var shouldOpen = active || openCats.indexOf(slug) !== -1;

        // Set initial state (no transition for first paint)
        sublist.style.transition = 'none';
        toggleSection(btn, sublist, slug, shouldOpen);

        // Re-enable transition after paint
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            sublist.style.transition = '';
          });
        });

        // Click handler
        btn.addEventListener('click', function () {
          var isOpen = btn.getAttribute('aria-expanded') === 'true';
          toggleSection(btn, sublist, slug, !isOpen);

          if (!isOpen) {
            if (openCats.indexOf(slug) === -1) openCats.push(slug);
          } else {
            openCats = openCats.filter(function (s) { return s !== slug; });
          }
          setOpenCats(openCats);
        });
      });
    }

    // Run on every Astro page transition + initial load
    document.addEventListener('astro:page-load', init);
    if (document.readyState !== 'loading') {
      init();
    }
  })();
</script>
