---
import type { Category } from '../data/notes';

interface Props {
  categories: Category[];
  currentPath: string;
}

const { categories, currentPath } = Astro.props;

function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(href + '/');
}

// Lucide icons as inline SVGs
const IconChevronDown = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>`;
---

<nav id="sidebar" class="sidebar" aria-label="Main navigation">
  <p class="sidebar-heading">Categories</p>

  {categories.map(cat => {
    const catActive = isActive(`/${cat.slug}`);
    const hasSubs = cat.subcategories.length > 0;
    return (
      <div class="sidebar-section" data-cat-slug={cat.slug}>
        {hasSubs ? (
          <button
            type="button"
            class:list={['sidebar-cat', 'sidebar-toggle', { active: catActive }]}
            aria-expanded={catActive ? 'true' : 'false'}
            aria-controls={`sublist-${cat.slug}`}
          >
            <span class="sidebar-cat-label">
              <span class="sidebar-chevron" aria-hidden="true" set:html={IconChevronDown} />
              <span class="sidebar-cat-text">{cat.name}</span>
            </span>
            <span class="sidebar-count">{cat.count}</span>
          </button>
        ) : (
          <a
            href={`/${cat.slug}/`}
            class:list={['sidebar-cat', { active: catActive }]}
          >
            <span class="sidebar-cat-label">
              <span class="sidebar-chevron-placeholder" />
              <span class="sidebar-cat-text">{cat.name}</span>
            </span>
            <span class="sidebar-count">{cat.count}</span>
          </a>
        )}

        {hasSubs && (
          <div id={`sublist-${cat.slug}`} class:list={['sidebar-sublist', { open: catActive }]}>
            <div class="sidebar-sublist-inner">
              {cat.subcategories.map(sub => (
                <a
                  href={`/${cat.slug}/${sub.slug}/`}
                  class:list={['sidebar-sub', { active: isActive(`/${cat.slug}/${sub.slug}`) }]}
                >
                  {sub.name}
                  <span class="sidebar-count">{sub.count}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    );
  })}

  <div class="sidebar-divider" />

  <div class="sidebar-section">
    <a href="/search/" class:list={['sidebar-cat', { active: currentPath === '/search/' }]}>
      <span class="sidebar-cat-label">
        <span class="sidebar-chevron-placeholder" />
        <span class="sidebar-cat-text">Search</span>
      </span>
    </a>
  </div>
</nav>

<script>
  (function() {
    const sidebar = document.getElementById('sidebar');
    if (!sidebar) return;

    // ── Accordion ──
    let openCats: string[] = [];
    try {
      const stored = localStorage.getItem('sidebar-open-cats');
      if (stored) openCats = JSON.parse(stored);
    } catch {}

    const isActivePath = (href: string) => {
      const path = location.pathname;
      return path === href || path.startsWith(href + '/');
    };

    function initAccordion() {
      sidebar!.querySelectorAll<HTMLButtonElement>('.sidebar-toggle').forEach(btn => {
        const section = btn.closest('.sidebar-section');
        const slug = section?.getAttribute('data-cat-slug');
        const sublist = btn.nextElementSibling as HTMLElement | null;
        if (!slug || !sublist) return;

        const active = isActivePath('/' + slug);
        const shouldOpen = openCats.includes(slug) || active;

        sublist.classList.toggle('open', shouldOpen);
        btn.setAttribute('aria-expanded', String(shouldOpen));
        btn.classList.toggle('expanded', shouldOpen);

        // Remove any stale listener by replacing the button
        const freshBtn = btn.cloneNode(true) as HTMLButtonElement;
        btn.parentNode!.replaceChild(freshBtn, btn);

        freshBtn.addEventListener('click', () => {
          const currentlyOpen = sublist.classList.contains('open');
          if (currentlyOpen) {
            sublist.classList.remove('open');
            freshBtn.setAttribute('aria-expanded', 'false');
            freshBtn.classList.remove('expanded');
            openCats = openCats.filter(s => s !== slug);
          } else {
            sublist.classList.add('open');
            freshBtn.setAttribute('aria-expanded', 'true');
            freshBtn.classList.add('expanded');
            if (!openCats.includes(slug)) openCats.push(slug);
          }
          localStorage.setItem('sidebar-open-cats', JSON.stringify(openCats));
        });
      });
    }

    initAccordion();
    document.addEventListener('astro:page-load', initAccordion);
  })();
</script>
